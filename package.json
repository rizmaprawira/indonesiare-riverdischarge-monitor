{
  "name": "indonesiare-riverdischarge-monitor",
  "version": "4.0.0",
  "private": true,
  "description": "Indonesia River Discharge Monitoring - Historical GloFAS data dashboard for IndonesiaRe Industry Research",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true});\"",
    "build": "npm run clean && npm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.20",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.1.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
